# Plantilla de variables de entorno para el backend Django.
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el archivo `.env` real al repositorio.

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
NGROK_HOST=tu-tunel.ngrok-free.app

# Base de datos PostgreSQL
DB_NAME=courier
DB_USER=postgres
DB_PASSWORD=tu-password
DB_HOST=localhost
DB_PORT=5432

# Google Maps (Directions, Distance Matrix, Geocoding)
GOOGLE_MAPS_API_KEY=tu-api-key-de-google-maps

# Clave Fernet para cifrado de media (firmas/fotos).
# Genérala con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEDIA_SECRET_KEY=tu-clave-fernet
